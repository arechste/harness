# Nested independent clones (per R0-Q6)
repos/*/

# Ephemeral working files
.tmp/
.tmp/persist/

# Claude Code's project-scope state directory.
# .claude/settings.json IS committed (shared project permissions — the harness
# operating regime). Everything else under .claude/ is per-machine:
#   - agents/ and commands/ are symlinks into adapters/claude/ created by
#     bootstrap/setup-host.sh
#   - settings.local.json, sessions, history, etc. are session state
.claude/*
!.claude/settings.json

# OS noise
.DS_Store
